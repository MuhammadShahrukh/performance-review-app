{
  "info": {
    "name": "Performance Review App (Local)",
    "description": "API collection for the Performance Review app running JSON-first (no DB).\n\nStart the dev server first:\n  npm run dev\n\nBase URL is the `base_url` collection variable (default http://localhost:3000).\n\nSeeded ids you can use immediately:\n- employee: emp-1 (Qamar Shahzad)\n- appraisal: apr-1 (emp-1, 2026)\n- question ids: q-1 .. q-12\n- grades: EXCEEDS | MEETS | BELOW",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000", "type": "string" },
    { "key": "developerId", "value": "emp-1", "type": "string" },
    { "key": "appraisalId", "value": "apr-1", "type": "string" },
    { "key": "year", "value": "2026", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST login (admin/CTO)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"hussain@myalfred.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Sign in. Sets an httpOnly session cookie that Postman stores and reuses. Run this before the Admin requests (Hussain is the ADMIN). Team Lead: shahrukh@myalfred.com. All passwords: password123."
          }
        },
        {
          "name": "POST logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Clear the session cookie."
          }
        }
      ]
    },
    {
      "name": "Admin (login as admin first)",
      "item": [
        {
          "name": "GET all users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/admin/users",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users"]
            },
            "description": "List EVERY user (all roles). Admin only — 403 without an admin session."
          }
        },
        {
          "name": "POST create user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@myalfred.com\",\n  \"password\": \"temp123\",\n  \"type\": \"MEMBER\",\n  \"role\": \"DEVELOPER\",\n  \"team\": \"CRM\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/users",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users"]
            },
            "description": "Create any user. Admin only. type = MEMBER | ADMIN (default MEMBER); role = CTO | TEAM_LEAD | DEVELOPER; team required for TEAM_LEAD/DEVELOPER, null for CTO."
          }
        },
        {
          "name": "DELETE user (cascade)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/admin/users/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "emp-4",
                  "description": "id of the user to delete"
                }
              ]
            },
            "description": "Delete a user and cascade all their review data (monthly entries, answers, appraisals). Admin only. Returns a summary of what was removed. 400 if you try to delete your own account."
          }
        }
      ]
    },
    {
      "name": "Admin — Questionnaire (login as admin first)",
      "item": [
        {
          "name": "GET all dimensions + questions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/admin/dimensions",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "dimensions"]
            },
            "description": "Every dimension (active + archived) with its questions. Admin only."
          }
        },
        {
          "name": "POST create dimension",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ownership & Craft\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/dimensions",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "dimensions"]
            },
            "description": "Create a dimension. Admin only."
          }
        },
        {
          "name": "PATCH dimension (rename / archive)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Renamed Dimension\",\n  \"active\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/dimensions/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "dimensions", ":id"],
              "variable": [{ "key": "id", "value": "dim-1" }]
            },
            "description": "Rename and/or archive/restore (active:false archives). Admin only."
          }
        },
        {
          "name": "DELETE dimension (only if never rated)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/admin/dimensions/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "dimensions", ":id"],
              "variable": [{ "key": "id", "value": "dim-1" }]
            },
            "description": "Hard-delete a dimension and its questions — 409 if any question has recorded ratings (archive instead). Admin only."
          }
        },
        {
          "name": "POST create question",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dimensionId\": \"dim-1\",\n  \"text\": \"Escalated risks early?\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/questions",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "questions"]
            },
            "description": "Add a question to a dimension. Admin only."
          }
        },
        {
          "name": "PATCH question (edit / archive)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Updated question text?\",\n  \"active\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/admin/questions/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "questions", ":id"],
              "variable": [{ "key": "id", "value": "q-1" }]
            },
            "description": "Edit text and/or archive/restore. Archiving the last active question of an active dimension is blocked (400). Admin only."
          }
        },
        {
          "name": "DELETE question (only if never rated)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/admin/questions/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "questions", ":id"],
              "variable": [{ "key": "id", "value": "q-1" }]
            },
            "description": "Hard-delete a question — 409 if it has recorded ratings (archive instead). Admin only."
          }
        }
      ]
    },
    {
      "name": "Reference",
      "item": [
        {
          "name": "GET dimensions + questions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/questions",
              "host": ["{{base_url}}"],
              "path": ["api", "questions"]
            },
            "description": "The 4 dimensions, each with its 3 questions. Reference data for building the monthly entry form."
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "GET employees",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users",
              "host": ["{{base_url}}"],
              "path": ["api", "users"]
            },
            "description": "List all developers (role DEVELOPER). Passwords are never returned."
          }
        },
        {
          "name": "POST create user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Developer\",\n  \"email\": \"newdev@myalfred.com\",\n  \"password\": \"secret123\",\n  \"type\": \"MEMBER\",\n  \"role\": \"DEVELOPER\",\n  \"team\": \"API\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users",
              "host": ["{{base_url}}"],
              "path": ["api", "users"]
            },
            "description": "Create a user. role must be CTO | TEAM_LEAD | DEVELOPER; type is MEMBER | ADMIN (defaults MEMBER); team is API|CRM|HRM|UI (required for TEAM_LEAD/DEVELOPER, must be null/omitted for CTO). 409 if email exists, 400 on bad input."
          }
        },
        {
          "name": "POST create user — bad role (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"X\",\n  \"email\": \"x@y.com\",\n  \"password\": \"x\",\n  \"role\": \"MANAGER\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users",
              "host": ["{{base_url}}"],
              "path": ["api", "users"]
            },
            "description": "Expects 400 — MANAGER is not a valid role."
          }
        }
      ]
    },
    {
      "name": "Entries",
      "item": [
        {
          "name": "GET entries for developer",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/entries/{{developerId}}?year={{year}}",
              "host": ["{{base_url}}"],
              "path": ["api", "entries", "{{developerId}}"],
              "query": [{ "key": "year", "value": "{{year}}" }]
            },
            "description": "All monthly entries (with their answers) for an employee. The ?year filter is optional."
          }
        },
        {
          "name": "POST monthly entry (12 answers)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"developerId\": \"{{developerId}}\",\n  \"month\": 2,\n  \"year\": 2026,\n  \"answers\": [\n    { \"questionId\": \"q-1\",  \"grade\": \"EXCEEDS\" },\n    { \"questionId\": \"q-2\",  \"grade\": \"MEETS\" },\n    { \"questionId\": \"q-3\",  \"grade\": \"MEETS\" },\n    { \"questionId\": \"q-4\",  \"grade\": \"EXCEEDS\" },\n    { \"questionId\": \"q-5\",  \"grade\": \"MEETS\" },\n    { \"questionId\": \"q-6\",  \"grade\": \"BELOW\" },\n    { \"questionId\": \"q-7\",  \"grade\": \"EXCEEDS\" },\n    { \"questionId\": \"q-8\",  \"grade\": \"MEETS\" },\n    { \"questionId\": \"q-9\",  \"grade\": \"MEETS\" },\n    { \"questionId\": \"q-10\", \"grade\": \"EXCEEDS\" },\n    { \"questionId\": \"q-11\", \"grade\": \"MEETS\" },\n    { \"questionId\": \"q-12\", \"grade\": \"EXCEEDS\" }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/entries",
              "host": ["{{base_url}}"],
              "path": ["api", "entries"]
            },
            "description": "Submit a monthly entry. Requires an answer for ALL 12 questions with valid grades.\n\n- 201 on success\n- 409 if an entry already exists for that developer/month/year\n- 400 if answers are incomplete, duplicated, or reference unknown questions"
          }
        },
        {
          "name": "POST monthly entry — incomplete (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"developerId\": \"{{developerId}}\",\n  \"month\": 3,\n  \"year\": 2026,\n  \"answers\": [\n    { \"questionId\": \"q-1\", \"grade\": \"MEETS\" }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/entries",
              "host": ["{{base_url}}"],
              "path": ["api", "entries"]
            },
            "description": "Expects 400 — only 1 of 12 answers supplied."
          }
        }
      ]
    },
    {
      "name": "Appraisals",
      "item": [
        {
          "name": "GET all appraisals (CTO list)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/appraisals?year={{year}}",
              "host": ["{{base_url}}"],
              "path": ["api", "appraisals"],
              "query": [{ "key": "year", "value": "{{year}}" }]
            },
            "description": "Every employee with their live-computed yearly summary (dimension breakdown, final grade, recommendation) and stored appraisal decision. ?year defaults to the current year."
          }
        },
        {
          "name": "POST generate appraisal",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"developerId\": \"{{developerId}}\",\n  \"year\": 2026\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/appraisals/generate",
              "host": ["{{base_url}}"],
              "path": ["api", "appraisals", "generate"]
            },
            "description": "Average all monthly data into a yearly grade and upsert the appraisal (existing CTO decision/note is preserved on regeneration). 400 if the employee has no entries for that year."
          }
        },
        {
          "name": "GET appraisal detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/appraisals/{{appraisalId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "appraisals", "{{appraisalId}}"]
            },
            "description": "Full detail: appraisal + employee + dimension breakdown (recomputed live). 404 if not found."
          }
        },
        {
          "name": "PUT approve appraisal",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"decision\": \"APPROVED\",\n  \"ctoNote\": \"Strong year, approved.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/appraisals/{{appraisalId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "appraisals", "{{appraisalId}}"]
            },
            "description": "CTO decision. decision must be APPROVED or REJECTED; ctoNote is optional. 400 on invalid decision, 404 if the appraisal doesn't exist."
          }
        },
        {
          "name": "PUT reject appraisal",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"decision\": \"REJECTED\",\n  \"ctoNote\": \"Needs another cycle.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/appraisals/{{appraisalId}}",
              "host": ["{{base_url}}"],
              "path": ["api", "appraisals", "{{appraisalId}}"]
            },
            "description": "Reject with a note."
          }
        }
      ]
    }
  ]
}
